    {
      "id": "prepare-email-data-v201",
      "name": "PrepareEmailData-Metlife-Final",
      "parameters": {
        "jsCode": "const item = $input.first().json;\nconst siniestro = item.siniestroId || \"SIN_NUMERO\";\nconst asegurado = item.asegurado || \"ASEGURADO\";\nconst supportEmail = \"soporte.gmm@pash.mx\";\n\nreturn {\n  json: {\n    ...item,\n    emailSubject: `📦 Expediente GMM - ${siniestro} - ${asegurado}`,\n    email_recipient: supportEmail,\n    emailBody: `\n      <h2>Expediente GMM Procesado - v2.0</h2>\n      <p>Se ha generado el paquete ZIP para el siniestro <b>${siniestro}</b>.</p>\n      <p><b>Asegurado:</b> ${asegurado}</p>\n      <p>Se incluyeron archivos de Anexos y Facturas descargados desde Supabase Storage.</p>\n    `\n  }\n};"
      },
      "position": [
        1008,
        -288
      ],
