      "name": "PrepFiles",
      "parameters": {
        "jsCode": "const items = $input.all();\nconst input = items[0].json;\nconst result = [];\n\nconst getFiles = (field) => {\n  if (!field) return [];\n  if (Array.isArray(field)) return field;\n  try { return JSON.parse(field); } catch (e) { return []; }\n};\n\nconst anexos = getFiles(input.grupoA_anexos);\nconst facturas = getFiles(input.grupoB_facturas);\n\nanexos.forEach(f => result.push({ json: { ...input, fileUrl: f.url, fileName: f.name, group: 'A' } }));\nfacturas.forEach(f => result.push({ json: { ...input, fileUrl: f.url, fileName: f.name, group: 'B' } }));\n\nreturn result;"
      },
      "position": [
        208,
        -288
      ],
      "type": "n8n-nodes-base.code",
      "typeVersion": 2
    },
    {
      "id": "dl-anexos-id-101",
