          "name": "Google Drive account"
        }
      }
    },
    {
      "parameters": {
        "operation": "toBinary",
        "sourceProperty": "body.documentoBase64",
        "options": {
          "fileName": "={{ $json.body.metadata.idSiniestro }}_Expediente.pdf",
          "mimeType": "=application/pdf",
          "encoding": "base64",
          "dataIsBase64": true
